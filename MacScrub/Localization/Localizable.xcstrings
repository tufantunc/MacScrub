  "strings": {
    "%lld of %lld keys held": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld of %lld keys held"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld / %lld tuş basılı"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld / %lld 个键已按住"
          }
        }
      }
    },
    "%lld seconds": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld seconds"
          }
        },
        "tr": {
