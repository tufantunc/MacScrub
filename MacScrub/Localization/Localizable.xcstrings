            "state": "translated",
            "value": "设置..."
          }
        }
      }
    },
    "menu.start_cleaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start Cleaning Mode"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Temizlik Modunu Başlat"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开始清洁模式"
          }
        }
      }
    },
    "menu.stop_cleaning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stop Cleaning Mode"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Temizlik Modunu Durdur"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "停止清洁模式"
          }
        }
      }
    },
    "overlay.hold_to_exit": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold all modifiers to exit"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Çıkmak için tüm modifier tuşlarını basılı tut"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按住所有修饰键退出"
          }
        }
      }
    },
    "overlay.locked": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keyboard and trackpad are locked."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Klavye ve trackpad kilitli."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "键盘和触控板已锁定。"
          }
        }
      }
    },
    "overlay.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cleaning Mode Active"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Temizlik Modu Aktif"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清洁模式已激活"
          }
        }
      }
    },
    "permission.description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MacScrub needs Accessibility access to block keyboard and trackpad input during cleaning."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "MacScrub, temizlik sırasında klavye ve trackpad girdilerini engellemek için Erişilebilirlik iznine ihtiyaç duyar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "MacScrub 需要辅助功能权限才能在清洁时阻止键盘和触控板输入。"
          }
        }
      }
    },
    "permission.done": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Done"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamam"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "完成"
          }
        }
      }
    },
    "permission.how_to_enable": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How to enable:"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nasıl etkinleştirilir:"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如何启用："
          }
        }
      }
    },
    "permission.open_settings": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open System Settings"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem Ayarlarını Aç"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开系统设置"
          }
        }
      }
    },
    "permission.step1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Open System Settings → Privacy & Security → Accessibility"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Sistem Ayarları → Gizlilik ve Güvenlik → Erişilebilirlik'i açın"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "1. 打开系统设置 → 隐私与安全 → 辅助功能"
          }
        }
      }
    },
    "permission.step2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "2. Click the + button and add MacScrub"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "2. + düğmesine tıklayın ve MacScrub'ü ekleyin"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "2. 点击 + 按钮并添加 MacScrub"
          }
        }
      }
    },
    "permission.step3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "3. Restart MacScrub"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "3. MacScrub'ü yeniden başlatın"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "3. 重新启动 MacScrub"
          }
        }
      }
    },
    "permission.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
