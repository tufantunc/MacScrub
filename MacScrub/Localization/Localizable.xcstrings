    "idle.support": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keyboard and trackpad input will be temporarily blocked."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Klavye ve trackpad girişi geçici olarak engellenecek."
