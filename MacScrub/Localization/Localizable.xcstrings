    "permission.step1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Open System Settings → Privacy & Security → Accessibility"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Sistem Ayarları → Gizlilik ve Güvenlik → Erişilebilirlik'i açın"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "1. 打开系统设置 → 隐私与安全 → 辅助功能"
          }
        }
      }
    },
    "permission.step2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "2. Click the + button and add MacScrub"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "2. + düğmesine tıklayın ve MacScrub'ü ekleyin"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "2. 点击 + 按钮并添加 MacScrub"
          }
        }
      }
    },
    "permission.step3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "3. Restart MacScrub"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "3. MacScrub'ü yeniden başlatın"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "3. 重新启动 MacScrub"
          }
        }
      }
    },
