    "permission.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accessibility Permission Required"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erişilebilirlik İzni Gerekli"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "需要辅助功能权限"
          }
        }
      }
    },
    "permission.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MacScrub needs Accessibility access to block keyboard and trackpad input during cleaning."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MacScrub, temizlik sırasında klavye ve trackpad girdilerini engellemek için Erişilebilirlik iznine ihtiyaç duyar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MacScrub 需要辅助功能权限才能在清洁时阻止键盘和触控板输入。"
          }
        }
      }
    },
    "permission.how_to_enable" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How to enable:"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nasıl etkinleştirilir:"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如何启用："
          }
        }
      }
    },
    "permission.step1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Open System Settings → Privacy & Security → Accessibility"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Sistem Ayarları → Gizlilik ve Güvenlik → Erişilebilirlik'i açın"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. 打开系统设置 → 隐私与安全 → 辅助功能"
          }
        }
      }
    },
    "permission.step2" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2. Click the + button and add MacScrub"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2. + düğmesine tıklayın ve MacScrub'ü ekleyin"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2. 点击 + 按钮并添加 MacScrub"
          }
        }
      }
    },
    "permission.step3" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3. Restart MacScrub"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3. MacScrub'ü yeniden başlatın"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3. 重新启动 MacScrub"
          }
        }
      }
    },
    "permission.open_settings" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open System Settings"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sistem Ayarlarını Aç"
