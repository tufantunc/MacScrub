            "value": "%lld saniye"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 秒"
          }
        }
      }
    },
    "🧼": {
      "comment": "A symbol representing cleaning.",
      "isCommentAutoGenerated": true
    },
    "🧼 MacScrub": {
      "comment": "The title of the app",
      "isCommentAutoGenerated": true
    },
    "menu.quit": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quit MacScrub"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "MacScrub'tan Çık"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "退出 MacScrub"
          }
        }
      }
    },
    "menu.settings": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Settings..."
          }
        },
        "tr": {
          "stringUnit": {
